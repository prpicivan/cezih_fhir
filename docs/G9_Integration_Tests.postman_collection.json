{
    "info": {
        "_postman_id": "a2b3c4d5-e6f7-48a9-b0c1-d2e3f4a5b6c7",
        "name": "WBS_FHIR G9 Integration Tests",
        "description": "Comprehensive collection for testing the 22 CEZIH G9 certification test cases through the WBS_FHIR middleware.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "TC-3: Get System Token",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/system-token",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "system-token"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Patient & Visit",
            "item": [
                {
                    "name": "TC-10: Search Patient (MBO)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/patient/search?mbo=123456789",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "patient",
                                "search"
                            ],
                            "query": [
                                {
                                    "key": "mbo",
                                    "value": "123456789"
                                }
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "TC-12: Start Visit",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"patientMbo\": \"123456789\",\n    \"class\": \"AMB\",\n    \"startDate\": \"{{currentIsoDate}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/visit/create",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "visit",
                                "create"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "Clinical Documentation",
            "item": [
                {
                    "name": "TC-18: Send Document",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"type\": \"AMBULATORY_REPORT\",\n    \"patientMbo\": \"123456789\",\n    \"visitId\": \"{{lastVisitId}}\",\n    \"closeVisit\": true,\n    \"diagnosisCode\": \"J00\",\n    \"anamnesis\": \"Test anamneza...\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/document/send",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "document",
                                "send"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        }
    ],
    "event": [
        {
            "listen": "prerequest",
            "script": {
                "type": "text/javascript",
                "exec": [
                    "pm.variables.set('currentIsoDate', new Date().toISOString());"
                ]
            }
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3010/api",
            "type": "string"
        },
        {
            "key": "token",
            "value": "YOUR_TOKEN_HERE",
            "type": "string"
        },
        {
            "key": "lastVisitId",
            "value": "",
            "type": "string"
        }
    ]
}