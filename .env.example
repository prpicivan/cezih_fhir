# Server Configuration
PORT=3010
NODE_ENV=development

# CEZIH Environment
CEZIH_BASE_URL=https://test.fhir.cezih.hr
CEZIH_FHIR_URL=https://test.fhir.cezih.hr/R4/fhir

# OAuth2 Client Credentials (System Authentication - Test Case 3)
CEZIH_CLIENT_ID=your_client_id_here
CEZIH_CLIENT_SECRET=your_client_secret_here
CEZIH_TOKEN_URL=https://test.fhir.cezih.hr/auth/realms/cezih/protocol/openid-connect/token

# OpenID Connect (End-User Authentication - Test Cases 1, 2)
CEZIH_OIDC_AUTH_URL=https://test.fhir.cezih.hr/auth/realms/cezih/protocol/openid-connect/auth
CEZIH_OIDC_REDIRECT_URI=http://localhost:3010/auth/callback
CEZIH_SSO_SESSION_HEADER=mod_auth_openid_session

# OID Registry (Test Case 6)
CEZIH_OID_REGISTRY_URL=https://test.fhir.cezih.hr/oid-registry

# Organization Identity
ORGANIZATION_OIB=12345678901
ORGANIZATION_HZZO_CODE=123456
ORGANIZATION_HZJZ_CODE=12345
ORGANIZATION_NAME=Privatna poliklinika
